generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========== 枚举 ==========

enum Visibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

// ========== Auth.js 标准四表 ==========

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  image        String?
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  accounts     Account[]
  sessions     Session[]
  stories      Story[]
  branches     StoryBranch[]

  @@map("users")
}

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ========== 业务模型 ==========

model Story {
  id            String     @id @default(cuid())
  title         String
  description   String?
  author        String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  rootSegmentId String?  @unique
  era           String?
  genre         String?

  ownerId       String
  owner         User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  visibility    Visibility @default(PRIVATE)
  publishedAt   DateTime?

  segments      StorySegment[]
  branches      StoryBranch[]
  characters    Character[]
  rootSegment   StorySegment?  @relation("StoryRoot", fields: [rootSegmentId], references: [id])
  directorStates DirectorState[]
  events        KeyEvent[]

  @@index([visibility, publishedAt])
  @@index([ownerId])
  @@map("stories")
}

model StorySegment {
  id                  String     @id @default(cuid())
  title               String?
  content             String     @db.Text
  isBranchPoint       Boolean    @default(false)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  storyId             String
  story               Story      @relation(fields: [storyId], references: [id], onDelete: Cascade)
  branchId            String
  parentSegmentId     String?
  imageUrls           String[]   @default([])
  timeline            Json?
  historicalReferences Json?
  narrativePace       String?
  mood                String?
  characterIds        String[]   @default([])
  visibility          Visibility @default(PRIVATE)

  // 反向关联
  rootOfStory         Story?          @relation("StoryRoot")
  branchSourceOf      StoryBranch[]   @relation("BranchSource")

  summaries           SegmentSummary[]

  @@index([storyId, branchId])
  @@index([storyId])
  @@index([branchId])
  @@map("story_segments")
}

model StoryBranch {
  id                     String     @id @default(cuid())
  title                  String
  description            String?
  sourceSegmentId        String
  storyId                String
  userDirection          String
  characterStateSnapshot Json?
  forkTimeline           Json?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  ownerId                String
  owner                  User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  visibility             Visibility @default(PRIVATE)

  story                  Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  sourceSegment          StorySegment @relation("BranchSource", fields: [sourceSegmentId], references: [id])

  @@index([storyId])
  @@index([ownerId])
  @@index([visibility])
  @@map("story_branches")
}

model Character {
  id             String   @id @default(cuid())
  name           String
  era            String
  role           String   @default("supporting")
  speechPatterns String   @default("")
  coreMotivation String   @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  traits         Json     @default("[]")
  relationships  Json     @default("[]")
  stateHistory   Json     @default("[]")

  storyId        String
  story          Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("characters")
}

model DirectorState {
  id                String   @id @default(cuid())
  storyId           String   @unique
  story             Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  characterStates   Json     @default("{}")
  worldVariables    Json     @default("{}")
  activeConstraints Json     @default("[]")
  updatedAt         DateTime @updatedAt

  @@map("director_states")
}

model SegmentSummary {
  id          String       @id @default(cuid())
  segmentId   String
  storyId     String
  branchId    String
  chainIndex  Int          @default(0)
  summary     String       @db.Text
  tokenCount  Int?
  originalTokenCount Int?
  aiGenerated Boolean      @default(false)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  segment     StorySegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([segmentId, branchId])
  @@index([storyId, branchId])
  @@map("segment_summaries")
}

model KeyEvent {
  id                    String   @id @default(cuid())
  storyId               String
  story                 Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  branchId              String
  segmentId             String?
  eventType             String
  description           String   @db.Text
  era                   String?
  year                  Int?
  season                String?
  narrativeTime         String?
  status                String   @default("active")
  importance            String   @default("major")
  involvedCharacterIds  Json     @default("[]")
  resolvedBySegmentId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([storyId])
  @@index([storyId, branchId])
  @@map("key_events")
}
